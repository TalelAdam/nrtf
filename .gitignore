# data (raw + processed datasets are heavy; track via DVC or download scripts)
data/raw/**
data/processed/**
data/external/**
data/calib/**
data/splits/**
data/eval/**
data/video/**
!data/**/README.md
!data/**/_manifest.json
!data/**/.gitkeep

# legacy ml-pipeline data dirs (kept for transition)
apps/ml-pipeline/src/data/raw/*
!apps/ml-pipeline/src/data/raw/.gitkeep
apps/ml-pipeline/src/data/processed/*
!apps/ml-pipeline/src/data/processed/.gitkeep
apps/ml-pipeline/src/data/external/*
!apps/ml-pipeline/src/data/external/.gitkeep
apps/ml-pipeline/checkpoints/*
!apps/ml-pipeline/checkpoints/.gitkeep
apps/ml-pipeline/experiments/*
!apps/ml-pipeline/experiments/.gitkeep
mlruns/

# models / checkpoints / edge artifacts (post-leak)
models/checkpoints/**
models/exports/**
!models/**/README.md
!models/**/.gitkeep
apps/edge-runtime/artifacts/**
!apps/edge-runtime/artifacts/**/README.md
!apps/edge-runtime/artifacts/**/.gitkeep

# binary model formats
*.pt
*.pth
*.onnx
*.tflite
*.gguf
*.bin.gguf
*.engine
*.trt
*.plan
*.pb
*.h5
*.safetensors
# DON'T ignore generated C-array headers — they're tracked because firmware needs them
!**/include/model/*.h

# DVC
.dvc/cache
.dvc/tmp
.dvc/plots

# video / images at scale
*.mp4
*.mov
*.mkv
*.avi
*.webm
data/**/*.jpg
data/**/*.jpeg
data/**/*.png
