ML_SERVICE_PORT=8002
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=nrtf-default

# Hugging Face (for foundation models)
HF_TOKEN=hf_...
HF_HOME=./hf_cache

# Data
DATA_RAW_DIR=./src/data/raw
DATA_PROCESSED_DIR=./src/data/processed
DATA_EXTERNAL_DIR=./src/data/external
CHECKPOINTS_DIR=./checkpoints

# Optional: NASA POWER, PVGIS API keys (mostly free)
NASA_POWER_USER=

# Backend (for inference logging)
BACKEND_URL=http://localhost:3000
