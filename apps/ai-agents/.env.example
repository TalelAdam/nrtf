# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Service config
AI_SERVICE_PORT=8001
AI_SERVICE_API_KEY=internal-key-change-me

# Backend (for callbacks + persistence)
BACKEND_URL=http://localhost:3000
BACKEND_API_KEY=internal-key-change-me

# ML inference
ML_SERVICE_URL=http://localhost:8002

# LangSmith (observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=...
LANGCHAIN_PROJECT=nrtf-hackathon

# Vector DB
CHROMA_PERSIST_DIR=./chroma_data
