    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "fastify": "^4.28.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "tsconfig-paths": "^4.2.0",
    "prettier": "^3.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  }
